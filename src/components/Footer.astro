---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 border-t border-gray-100 bg-white">
    <div class="container mx-auto px-4 text-center text-gray-400">
        <div class="flex justify-center items-center gap-8 mb-8">
            <a href={`${import.meta.env.BASE_URL}privacy`} class="hover:text-indigo-600 transition-colors">Privacy</a>
            <a href={`${import.meta.env.BASE_URL}eula`} class="hover:text-indigo-600 transition-colors">EULA</a>
            <a href={`${import.meta.env.BASE_URL}terms`} class="hover:text-indigo-600 transition-colors">Terms</a>
        </div>
        <p>&copy; {currentYear} Footprints App. All rights reserved.</p>
    </div>
</footer>
