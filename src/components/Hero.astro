---
const APP_STORE_URL =
    "https://apps.apple.com/us/app/footprints-social-logging/id6756193003?uo=4";
---

<section class="relative pt-32 pb-48 lg:pt-48 lg:pb-64 overflow-hidden">
    <div
        class="container mx-auto px-4 sm:px-6 lg:px-8 relative text-center z-10"
    >
        <div class="mb-5">
            <img
                src={`${import.meta.env.BASE_URL}footprint_nobackground.png`}
                alt="Footprints Logo"
                class="h-32 w-auto mx-auto mix-blend-multiply"
            />
        </div>

        <h1
            class="text-5xl md:text-7xl font-bold tracking-tight text-gray-900 mb-6"
        >
            Turn Moments into <br class="hidden md:block" />
            <span class="text-blue-600">Ongoing Trails</span>
        </h1>

        <p
            class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed"
        >
            Capture detailed footprints with photos, time, location, and
            thoughts. Organize them into timelines to track habits, log trips,
            or document places.
        </p>

        <div class="flex flex-col items-center gap-4">
            <a
                href={APP_STORE_URL}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Install Footprints on iOS from the App Store"
                class="group inline-flex items-center gap-3 rounded-2xl bg-gray-900 px-6 py-4 text-white shadow-xl shadow-gray-300/60 transition-all duration-300 hover:-translate-y-1 hover:bg-black hover:shadow-2xl hover:shadow-gray-400/60 active:scale-95"
            >
                <svg
                    class="h-7 w-7 flex-shrink-0"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M17.05 12.34c-.03-3.06 2.5-4.53 2.61-4.6-1.42-2.08-3.63-2.36-4.41-2.39-1.88-.19-3.66 1.1-4.62 1.1-.95 0-2.43-1.08-3.99-1.05-2.05.03-3.94 1.19-5 3.03-2.13 3.7-.54 9.18 1.53 12.18 1.01 1.47 2.22 3.12 3.81 3.06 1.53-.06 2.1-.99 3.94-.99 1.84 0 2.36.99 3.98.96 1.64-.03 2.68-1.5 3.69-2.98 1.16-1.7 1.64-3.34 1.66-3.43-.04-.02-3.17-1.22-3.2-4.89ZM14.02 3.37c.84-1.02 1.41-2.44 1.26-3.85-1.21.05-2.68.81-3.55 1.82-.78.9-1.46 2.35-1.28 3.73 1.35.1 2.73-.69 3.57-1.7Z"
                    ></path>
                </svg>
                <span class="text-left leading-tight">
                    <span class="block text-xs font-medium text-gray-300"
                        >Available now</span
                    >
                    <span class="block text-lg font-semibold"
                        >Install on iOS</span
                    >
                </span>
            </a>

            <p class="text-sm text-gray-500">
                Free on the App Store for iPhone and iPad.
            </p>
        </div>
    </div>
</section>
